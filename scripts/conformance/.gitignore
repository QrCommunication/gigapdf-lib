# Generated fixtures + validation reports (produced by run.sh / gen-fixtures.mjs).
fixtures/

# Local Python venv for the vendored validators (created by run.sh fallback path).
.venv/
__pycache__/
*.pyc

# Official reference schemas are large + license-restricted — provisioned by
# fetch-schemas.sh from pinned, checksummed URLs at gate time, never committed.
schemas/
# Cached raw schema downloads (the 53 MB ECMA-376 archive, etc.).
.schema-cache/

# NOTE: validators/*.py, validators/requirements.txt, fetch-schemas.sh and
# known-schema-issues.json ARE committed (the gate's self-contained logic +
# the documented violation baseline). They are intentionally not ignored.
